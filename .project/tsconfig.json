{
  "compilerOptions": {
    // ─── Cible & Modules ────────────────────────────────────────────────────
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // ─── Output ─────────────────────────────────────────────────────────────
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,  // Relie .d.ts → sources pour le hover VSCode
    "sourceMap": true,
    "removeComments": false, // CRITIQUE : préserve les JSDoc dans les .d.ts

    // ─── Strict ─────────────────────────────────────────────────────────────
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,

    // ─── Imports ────────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // ─── Paths / Aliases ────────────────────────────────────────────────────
    "paths": {
      "@/*":             ["./*"],
      "@core/*":         ["./core/*"],
      "@modules/*":      ["./modules/*"],
      "@tests/*":        ["./tests/*"],
      "@sangho-types/*": ["./types/*"],
      "@utils/*":        ["./utils/*"]
    },

    // ─── Qualité ────────────────────────────────────────────────────────────
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "*.ts",
    "core/**/*",
    "modules/**/*",
    "types/**/*",
    "utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/**/*.test.ts",
    "tests/**/*.spec.ts"
  ]
}